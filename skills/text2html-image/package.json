{
  "name": "text2html-image",
  "version": "1.0.0",
  "description": "跨境电商图片生产工作流 Skill 系列，基于 HTML/CSS 的电商图片生产工作流，支持多语言版本批量生成。",
  "scripts": {
    "start": "node scripts/start.js",
    "project:init": "node scripts/project-init.js",
    "build": "node scripts/build.js",
    "quality-check": "node scripts/quality-check.js",
    "review:score": "node scripts/review-score.js",
    "batch-export": "node scripts/batch-export.js",
    "render:profile": "node scripts/render-fast.js --profile-only",
    "export-fast": "node scripts/render-fast.js",
    "flood-cutout": "node scripts/flood-cutout.js",
    "audit:dom": "node scripts/audit-dom.js",
    "route:assets": "node scripts/route-assets.js",
    "template:check": "node scripts/template-check.js",
    "copy-schema": "node scripts/copy-schema.js",
    "visual:intake": "node scripts/visual-intake.js",
    "cutout:decompose": "node scripts/cutout-decompose.js",
    "visual:review": "node scripts/visual-review.js",
    "audit:imagegen": "node scripts/audit-imagegen-candidates.js",
    "audit:routes": "node scripts/audit-expected-routes.js",
    "audit:source-truth": "node scripts/audit-source-truth-bitmaps.js",
    "audit:bitmap-layers": "node scripts/audit-bitmap-layers.js",
    "audit:review-gates": "node scripts/audit-review-gates.js",
    "audit:asset-readiness": "node scripts/audit-asset-readiness.js",
    "audit:source-truth-acquisition": "node scripts/audit-source-truth-acquisition.js",
    "test": "node scripts/test.js",
    "install:all": "node scripts/install-skill.js",
    "install:claude": "node scripts/install-skill.js --target claude",
    "install:codex": "node scripts/install-skill.js --target codex"
  },
  "keywords": [
    "ecommerce",
    "image-generation",
    "html-css",
    "multilingual",
    "workflow"
  ],
  "author": "Tashima Meru",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "css-tree": "^3.2.1",
    "parse5": "^8.0.1",
    "pngjs": "^7.0.0"
  }
}
